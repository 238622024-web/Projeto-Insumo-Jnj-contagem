Options -Indexes

<IfModule mod_authz_core.c>
  <FilesMatch "\.(sql|md)$">
    Require all denied
  </FilesMatch>

  <FilesMatch "^(check_login_debug|reset_password|set_avatar|check_avatars)\.php$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "\.(sql|md)$">
    Order allow,deny
    Deny from all
  </FilesMatch>

  <FilesMatch "^(check_login_debug|reset_password|set_avatar|check_avatars)\.php$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
