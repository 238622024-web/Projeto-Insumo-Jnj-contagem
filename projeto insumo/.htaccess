Options -Indexes

<IfModule mod_authz_core.c>
  <FilesMatch "^(config\.php|composer\.json|php\.ini|README-SETUP\.txt|ESTRUTURA_PROJETO\.md|INDICE_DOCUMENTACAO\.md)$">
    Require all denied
  </FilesMatch>

  <FilesMatch "\.(sql|bak|ini|env)$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(config\.php|composer\.json|php\.ini|README-SETUP\.txt|ESTRUTURA_PROJETO\.md|INDICE_DOCUMENTACAO\.md)$">
    Order allow,deny
    Deny from all
  </FilesMatch>

  <FilesMatch "\.(sql|bak|ini|env)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^db_backups/ - [F,L]
  RewriteRule ^database/(check_login_debug|reset_password|set_avatar|check_avatars)\.php$ - [F,L]
</IfModule>
